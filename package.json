{
  "name": "potato",
  "displayName": "Potato",
  "description": "Personal VS Code orchestrator for private OpenAI-compatible AI endpoints.",
  "version": "0.0.1",
  "publisher": "local",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sifat-Ahmed/potato.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:orchestrator.workbench",
    "onCommand:orchestrator.open"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "orchestrator.open",
        "title": "Potato: Open"
      },
      {
        "command": "orchestrator.resetDemoData",
        "title": "Potato: Reset Starter Agents"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "orchestrator",
          "title": "Potato",
          "icon": "resources/orchestrator.svg"
        }
      ]
    },
    "views": {
      "orchestrator": [
        {
          "id": "orchestrator.workbench",
          "type": "webview",
          "name": "Workforce"
        }
      ]
    },
    "configuration": {
      "title": "Potato",
      "properties": {
        "orchestrator.autoDelegate": {
          "type": "boolean",
          "default": true,
          "description": "Ask the manager agent to create delegation tasks for specialized agents."
        },
        "orchestrator.maxParallelAgents": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 12,
          "description": "Maximum number of delegated agent calls to run at once."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "npm run compile && node --test test/orchestrator-protocol.test.js",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "npm run compile && vsce package --out potato.vsix"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.36"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.19.0",
    "typescript": "^5.4.5"
  }
}
